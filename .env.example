# Copy to .env and fill in. .env is gitignored.

# LLM (vLLM, OpenAI-compatible)
LLM_BASE_URL=https://inferenced2.beestorm.ai
LLM_API_KEY=replace-with-your-key
LLM_MODEL=LeaderboardModel1/Agents-A1-AutoRound-W4A16-RTN

# TTS
TTS_BASE_URL=https://tts.beestorm.ai
TTS_VOICE=Ryan
TTS_LANGUAGE=English
TTS_API_KEY=

# STT (Qwen3-ASR). STT_LANGUAGE is an ISO-639-1 code (en, pt, ...) or blank for auto.
STT_BASE_URL=https://stt.beestorm.ai
STT_MODEL=Qwen/Qwen3-ASR-0.6B
STT_LANGUAGE=en
STT_API_KEY=

# Sampling
LLM_TEMPERATURE=0.7
LLM_SEED=42
LLM_MAX_TOKENS=512
# Reasoning model: keep thinking off so speakable content streams immediately.
LLM_ENABLE_THINKING=false

# Phrase aggregation
PHRASE_MIN_CHARS=20
# Edge device sessions stay hot this long (seconds) since last use.
EDGE_SESSION_TTL_S=300

# Server
HOST=127.0.0.1
PORT=8000
